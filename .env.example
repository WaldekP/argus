# Skopiuj ten plik jako .env i uzupełnij wartości.
# Zmienne z prefiksem EXPO_PUBLIC_ trafiają do bundla klienta — tylko wartości publiczne!

# Supabase (projekt Argus, EU/Frankfurt) — Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# PostHog (opcjonalny; projekt "Argus", host EU: https://eu.i.posthog.com).
# Brak klucza = analityka wyłączona.
EXPO_PUBLIC_POSTHOG_KEY=

# --------------------------------------------------------------------------
# Sekrety Edge Functions (ANTHROPIC_API_KEY, SUPABASE_SERVICE_ROLE_KEY)
# ustawiamy WYŁĄCZNIE przez `supabase secrets set NAZWA=wartość`,
# nigdy w tym pliku ani nigdzie w kodzie klienta.
# --------------------------------------------------------------------------
